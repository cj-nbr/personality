---
interface Props {
  countries: Array<{
    slug: string;
    name: string;
    flag: string;
    continent: string;
    overview: string;
  }>;
  searchQuery: string;
  selectedContinent: string;
}

const { countries, searchQuery, selectedContinent } = Astro.props;
---

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  {countries.map(country => (
    <a 
      href={`/countries/${country.slug}`}
      class="group rounded-xl border border-hairline bg-canvas p-6 transition hover:border-primary hover:shadow-lg dark:border-white/15 dark:bg-primary dark:hover:border-primary"
    >
      <img src={country.flag} alt={country.name} class="h-10 w-auto mb-4 object-contain" />
      <h3 class="text-lg font-semibold text-ink group-hover:text-primary dark:text-on-primary">{country.name}</h3>
      <p class="text-sm text-muted mt-1 dark:text-muted">{country.continent}</p>
      <p class="text-sm text-body mt-2 line-clamp-2 dark:text-muted">{country.overview}</p>
      <span class="inline-block mt-4 text-sm font-medium text-link group-hover:underline dark:text-link" data-i18n="countries.view_taxes">View taxes</span>
    </a>
  ))}
</div>
