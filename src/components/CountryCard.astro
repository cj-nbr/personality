---
interface Props {
  countries: Array<{
    slug: string;
    name: string;
    flag: string;
    continent: string;
    overview: string;
  }>;
  searchQuery: string;
  selectedContinent: string;
}

const { countries, searchQuery, selectedContinent } = Astro.props;
---

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
  {countries.map(country => (
    <a 
      href={`/countries/${country.slug}`}
      class="group rounded-xl border border-hairline bg-canvas p-6 transition hover:border-primary hover:shadow-lg"
    >
      <div class="text-4xl mb-4">{country.flag}</div>
      <h3 class="text-lg font-semibold text-ink group-hover:text-primary">{country.name}</h3>
      <p class="text-sm text-muted mt-1">{country.continent}</p>
      <p class="text-sm text-body mt-2 line-clamp-2">{country.overview}</p>
      <span class="inline-block mt-4 text-sm font-medium text-link group-hover:underline">
        View taxes →
      </span>
    </a>
  ))}
</div>
