---
interface Props {
  question: {
    id: number;
    dimension: string;
    text: string;
    optionA: { text: string; value: number };
    optionB: { text: string; value: number };
  };
  selectedAnswer?: number;
  onSelect: (value: number) => void;
}

const { question, selectedAnswer, onSelect } = Astro.props;
---

<div class="w-full">
  <p class="mb-4 font-mono text-xs uppercase tracking-wide text-mute">
    {question.dimension === 'EI' ? 'Energy Direction' : 
     question.dimension === 'SN' ? 'Information Gathering' : 
     question.dimension === 'TF' ? 'Decision Making' : 
     question.dimension === 'AT' ? 'Identity' : 'Lifestyle'}
  </p>
  
  <h2 class="mb-10 text-balance font-semibold text-2xl text-ink sm:text-3xl dark:text-on-primary">
    {question.text}
  </h2>

  <div class="question-container" data-question-id={question.id} data-selected-answer={selectedAnswer ?? ''}>
    <div class="flex items-stretch gap-4">
      <label class="option-label group flex-1 cursor-pointer rounded-xl border-2 border-hairline bg-canvas p-6 text-center transition-all duration-200 hover:border-hairline-strong dark:border-white/15 dark:bg-primary" data-value={question.optionA.value}>
        <input 
          type="radio" 
          name={`question-${question.id}`} 
          value={question.optionA.value} 
          class="sr-only"
        />
        <span class="text-base font-medium text-ink dark:text-on-primary">{question.optionA.text}</span>
      </label>

      <label class="option-label group flex-1 cursor-pointer rounded-xl border-2 border-hairline bg-canvas p-6 text-center transition-all duration-200 hover:border-hairline-strong dark:border-white/15 dark:bg-primary" data-value={question.optionB.value}>
        <input 
          type="radio" 
          name={`question-${question.id}`} 
          value={question.optionB.value} 
          class="sr-only"
        />
        <span class="text-base font-medium text-ink dark:text-on-primary">{question.optionB.text}</span>
      </label>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var containers = document.querySelectorAll('.question-container');
    
    containers.forEach(function(container) {
      var questionId = container.getAttribute('data-question-id');
      var selectedAnswer = container.getAttribute('data-selected-answer');
      var labels = container.querySelectorAll('.option-label');
      
      function selectLabel(label) {
        labels.forEach(function(l) {
          l.style.border = '';
          l.style.backgroundColor = '';
          l.style.boxShadow = '';
        });
        
        var isDark = document.documentElement.classList.contains('dark');
        var borderColor = isDark ? '#4ade80' : '#22c55e';
        var bgColor = isDark ? 'rgba(74, 222, 128, 0.1)' : '#f0fdf4';
        var glow = '0 0 15px rgba(34, 197, 94, 0.4), 0 0 30px rgba(34, 197, 94, 0.2)';
        
        label.style.border = '2px solid ' + borderColor;
        label.style.backgroundColor = bgColor;
        label.style.boxShadow = glow;
      }
      
      if (selectedAnswer && selectedAnswer !== '') {
        labels.forEach(function(label) {
          if (label.getAttribute('data-value') === selectedAnswer) {
            selectLabel(label);
          }
        });
      }
      
      labels.forEach(function(label) {
        label.addEventListener('click', function() {
          var value = this.getAttribute('data-value');
          selectLabel(this);
          
          document.dispatchEvent(new CustomEvent('answer-selected', { 
            detail: { value: value, questionId: questionId } 
          }));
        });
      });
    });
  })();
</script>
