---
interface Props {
  value: string;
  onInput: (value: string) => void;
  placeholder?: string;
}

const { value, onInput, placeholder = "Search..." } = Astro.props;
---

<div class="relative">
  <input
    type="text"
    value={value}
    oninput={(e) => onInput((e.target as HTMLInputElement).value)}
    placeholder={placeholder}
    class="w-full rounded-lg border border-hairline bg-canvas px-4 py-2 pl-10 text-ink placeholder:text-muted focus:border-primary focus:outline-none"
  />
  <svg class="absolute left-3 top-2.5 h-5 w-5 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
</div>
