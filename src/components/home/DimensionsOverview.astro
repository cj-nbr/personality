---
interface Dimension {
  code: string;
  title: string;
  description: string;
}

interface Props {
  dimensions?: Dimension[];
}

const defaultDimensions = [
  {
    code: "EI",
    title: "Energy",
    description:
      "Where you focus your energy and how you recharge. Extraverts gain energy from external stimulation and social interaction. Introverts recharge through solitude and internal reflection.",
  },
  {
    code: "SN",
    title: "Information",
    description:
      "How you take in information and what you trust. Sensing types prefer concrete, factual information and experience. Intuitive types prefer abstract patterns, possibilities, and future implications.",
  },
  {
    code: "TF",
    title: "Decisions",
    description:
      "What you prioritize when choices get hard. Thinking types prioritize objective logic and principles. Feeling types prioritize personal values, harmony, and the impact on people.",
  },
  {
    code: "JP",
    title: "Lifestyle",
    description:
      "How you structure your world and handle change. Judging types prefer order, planning, and clear decisions. Perceiving types prefer flexibility, spontaneity, and keeping options open.",
  },
];

const { dimensions = defaultDimensions } = Astro.props;
---

<section class="bg-canvas-soft dark:bg-primary">
  <div class="mx-auto max-w-[1000px] px-6 py-20 sm:py-28">
    <div class="text-center">
      <h2 class="text-balance font-semibold tracking-[-1.2px] text-ink text-[32px] leading-[1.1] sm:text-[40px] dark:text-on-primary">
        Four Dimensions. One Whole Picture.
      </h2>
      <p class="mt-4 max-w-2xl mx-auto font-mono text-base leading-7 text-body dark:text-mute">
        Personality isn't one trait — it's a combination of four spectrums. Together, they create a complete map of how you engage with the world.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {dimensions.map((dim) => (
        <a
          href="/personality-dimensions"
          class="group rounded-lg border border-hairline bg-canvas p-8 transition hover:border-hairline-strong dark:border-white/15 dark:bg-primary dark:hover:border-white/30"
        >
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs uppercase tracking-wide text-link">{dim.code}</span>
            <span class="h-px flex-1 bg-hairline dark:bg-white/10" aria-hidden="true"></span>
          </div>
          <h3 class="mt-3 text-lg font-semibold text-ink group-hover:text-link dark:text-on-primary dark:group-hover:text-link">
            {dim.title}
          </h3>
          <p class="mt-3 text-sm leading-7 text-body dark:text-mute">{dim.description}</p>
          <span class="mt-4 inline-block text-sm font-medium text-link">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>
