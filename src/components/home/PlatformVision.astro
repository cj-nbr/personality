---
interface Module {
  title: string;
  description: string;
  status: "now" | "soon" | "future";
}

interface Props {
  modules?: Module[];
}

const defaultModules = [
  {
    title: "16 Personality Test",
    description: "Discover your Myers-Briggs type with our free 48-question assessment.",
    status: "now" as const,
  },
  {
    title: "EQ Assessment",
    description: "Measure emotional intelligence and understand how you process feelings.",
    status: "soon" as const,
  },
  {
    title: "IQ Assessment",
    description: "Explore cognitive strengths across logical, spatial, and verbal reasoning.",
    status: "soon" as const,
  },
  {
    title: "Mindset Assessment",
    description: "Identify whether you have a growth or fixed mindset and how it shapes your choices.",
    status: "soon" as const,
  },
  {
    title: "Career Assessment",
    description: "Match your personality, skills, and interests to fulfilling career paths.",
    status: "soon" as const,
  },
  {
    title: "Learning Style Assessment",
    description: "Understand whether you learn best through visual, auditory, or hands-on methods.",
    status: "soon" as const,
  },
  {
    title: "AI Coach",
    description: "Get personalized insights and answers powered by artificial intelligence.",
    status: "future" as const,
  },
  {
    title: "Premium Reports",
    description: "Deep-dive PDFs with advanced analysis, comparisons, and actionable guidance.",
    status: "future" as const,
  },
  {
    title: "Progress Dashboard",
    description: "Track your results across assessments over time and see your growth.",
    status: "future" as const,
  },
];

const { modules = defaultModules } = Astro.props;

const nowItems = modules.filter((m) => m.status === "now");
const soonItems = modules.filter((m) => m.status === "soon");
const futureItems = modules.filter((m) => m.status === "future");
---

<section class="bg-canvas-soft dark:bg-primary">
  <div class="mx-auto max-w-[1000px] px-6 py-20 sm:py-28">
    <div class="text-center">
      <h2 class="text-balance font-semibold tracking-[-1.2px] text-ink text-[32px] leading-[1.1] sm:text-[40px] dark:text-on-primary">
        One Assessment Is Just the Beginning.
      </h2>
      <p class="mt-6 max-w-2xl mx-auto font-mono text-base leading-7 text-body dark:text-mute">
        Personality is one dimension of who you are. Our platform is designed to help you explore all of them — from how you think and feel, to how you learn, lead, and grow.
      </p>
    </div>

    <div class="mt-16 space-y-8">
      {nowItems.length > 0 && (
        <div>
          <p class="font-mono text-xs uppercase tracking-wide text-link">Available Now</p>
          <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {nowItems.map((item) => (
              <a
                href="/personality-test"
                class="group rounded-lg border-2 border-link bg-canvas p-6 transition hover:shadow-lg dark:bg-primary"
              >
                <h3 class="text-lg font-semibold text-ink group-hover:text-link dark:text-on-primary dark:group-hover:text-link">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-body dark:text-mute">{item.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      {soonItems.length > 0 && (
        <div>
          <p class="font-mono text-xs uppercase tracking-wide text-mute">Coming Soon</p>
          <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {soonItems.map((item) => (
              <div class="rounded-lg border border-hairline bg-canvas p-6 dark:border-white/15 dark:bg-primary">
                <h3 class="text-lg font-semibold text-ink dark:text-on-primary">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-body dark:text-mute">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {futureItems.length > 0 && (
        <div>
          <p class="font-mono text-xs uppercase tracking-wide text-mute">Future</p>
          <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
            {futureItems.map((item) => (
              <div class="rounded-lg border border-dashed border-hairline-strong bg-canvas p-6 dark:border-white/15 dark:bg-primary">
                <h3 class="text-lg font-semibold text-ink dark:text-on-primary">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-body dark:text-mute">{item.description}</p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <div class="mt-14 text-center">
      <a
        href="/personality-test"
        class="rounded-pill bg-primary px-8 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary"
      >
        Take the Personality Test
      </a>
    </div>
  </div>
</section>
