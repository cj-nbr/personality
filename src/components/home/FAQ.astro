---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const defaultItems = [
  {
    question: "Is it really free?",
    answer: "Yes. The core assessment and results are completely free. There are no hidden charges or premium paywalls for the basic report.",
  },
  {
    question: "How long does it take?",
    answer: "The test consists of 48 questions and typically takes about 5 minutes to complete. You can save your progress and return later if needed.",
  },
  {
    question: "Do I need to create an account?",
    answer: "No account is required. Your progress is saved locally in your browser, and you can access your results without signing up.",
  },
  {
    question: "Is it scientifically based?",
    answer: "It is based on established dimensional personality theory. It measures preferences, not diagnoses, and is designed to encourage self-reflection rather than rigid categorization.",
  },
  {
    question: "Can my personality change over time?",
    answer: "Core preferences tend to remain stable, but context and self-awareness can shift your responses. The goal is greater flexibility, not becoming a different type.",
  },
];

const { items = defaultItems } = Astro.props;
---

<section class="border-y border-hairline bg-canvas dark:border-white/10 dark:bg-primary">
  <div class="mx-auto max-w-[800px] px-6 py-20 sm:py-28">
    <div class="text-center">
      <h2 class="text-balance font-semibold tracking-[-1.2px] text-ink text-[32px] leading-[1.1] sm:text-[40px] dark:text-on-primary">
        Quick Answers.
      </h2>
      <p class="mt-4 max-w-2xl mx-auto font-mono text-base leading-7 text-body dark:text-mute">
        Common questions before you start.
      </p>
    </div>

    <div class="mt-16 space-y-4">
      {items.map((item, idx) => (
        <details class="group rounded-lg border border-hairline bg-canvas-soft dark:border-white/15 dark:bg-primary">
           <summary class="flex cursor-pointer items-center justify-between p-6 text-base font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/5">
            {item.question}
            <svg
              class="h-5 w-5 shrink-0 text-mute transition-transform duration-200 group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 text-sm leading-7 text-body dark:text-mute">
            {item.answer}
          </div>
        </details>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a
        href="/faq"
        class="text-sm font-medium text-link hover:text-link-deep dark:text-link dark:hover:text-link-deep"
      >
        Still have questions? Read our full FAQ →
      </a>
    </div>
  </div>
</section>
