---
interface Props {
  headline?: string;
  subheadline?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  headline = "Understand How You Actually Work.",
  subheadline = "A free self-discovery platform built on science. Start with our personality assessment and expand into IQ, EQ, mindset, and career insights — all in one place.",
  primaryCta = { label: "Take the Free Assessment", href: "/personality-test" },
  secondaryCta = { label: "Explore the Platform", href: "/personality-types" },
} = Astro.props;
---

<section
  class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-32"
  aria-labelledby="hero-headline"
>
  <div
    class="pointer-events-none absolute inset-0 opacity-60 dark:opacity-70"
    aria-hidden="true"
  >
    <div class="mesh-gradient absolute inset-0" />
  </div>

  <div class="relative mx-auto max-w-[1400px] px-6">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-2xl">
        <h1
          id="hero-headline"
          class="shine-text max-w-3xl text-balance font-semibold tracking-[-2.4px] text-ink text-[40px] leading-[1.05] sm:text-[48px] dark:text-on-primary"
        >
          {headline}
        </h1>

        <p class="mt-6 max-w-xl font-mono text-base leading-7 text-body dark:text-mute">
          {subheadline}
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a
            href={primaryCta.href}
            class="rounded-pill bg-primary px-8 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary"
          >
            {primaryCta.label}
          </a>
          <a
            href={secondaryCta.href}
            class="rounded-pill border border-hairline bg-canvas px-8 py-3 text-base font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:bg-transparent dark:text-on-primary dark:hover:bg-white/10"
          >
            {secondaryCta.label}
          </a>
        </div>
      </div>

      <div class="relative flex items-center justify-center lg:justify-end">
        <div class="relative h-[300px] w-full max-w-[400px] sm:h-[400px] sm:max-w-[500px]">
          <svg
            viewBox="0 0 400 400"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="h-full w-full"
            aria-hidden="true"
          >
            <defs>
              <linearGradient id="heroGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#007cf0" />
                <stop offset="100%" stop-color="#00dfd8" />
              </linearGradient>
              <linearGradient id="heroGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#7928ca" />
                <stop offset="100%" stop-color="#ff0080" />
              </linearGradient>
              <linearGradient id="heroGrad3" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#ff4d4d" />
                <stop offset="100%" stop-color="#f9cb28" />
              </linearGradient>
              <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="4" result="coloredBlur" />
                <feMerge>
                  <feMergeNode in="coloredBlur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>

            <g transform="translate(200, 200)">
              <circle
                r="140"
                stroke="url(#heroGrad1)"
                stroke-width="1.5"
                fill="none"
                opacity="0.5"
                stroke-dasharray="8 8"
              >
                <animateTransform
                  attributeName="transform"
                  type="rotate"
                  from="0"
                  to="360"
                  dur="60s"
                  repeatCount="indefinite"
                />
              </circle>

              <circle
                r="100"
                stroke="url(#heroGrad2)"
                stroke-width="2"
                fill="none"
                opacity="0.6"
              >
                <animateTransform
                  attributeName="transform"
                  type="rotate"
                  from="360"
                  to="0"
                  dur="45s"
                  repeatCount="indefinite"
                />
              </circle>

              <circle
                r="60"
                stroke="url(#heroGrad3)"
                stroke-width="1.5"
                fill="none"
                opacity="0.4"
                stroke-dasharray="4 4"
              >
                <animateTransform
                  attributeName="transform"
                  type="rotate"
                  from="0"
                  to="-360"
                  dur="35s"
                  repeatCount="indefinite"
                />
              </circle>
            </g>

            <g transform="translate(200, 200)">
              <circle r="6" fill="#007cf0" opacity="0.9" filter="url(#glow)">
                <animate attributeName="r" values="6;8;6" dur="4s" repeatCount="indefinite" />
                <animate attributeName="opacity" values="0.9;1;0.9" dur="4s" repeatCount="indefinite" />
              </circle>
            </g>

            <g transform="translate(200, 200)">
              <circle cx="140" cy="0" r="5" fill="#7928ca" opacity="0.8">
                <animate attributeName="r" values="5;6;5" dur="3s" repeatCount="indefinite" />
              </circle>
              <circle cx="-140" cy="0" r="5" fill="#00dfd8" opacity="0.8">
                <animate attributeName="r" values="5;6;5" dur="3.5s" repeatCount="indefinite" />
              </circle>
              <circle cx="0" cy="140" r="5" fill="#ff0080" opacity="0.8">
                <animate attributeName="r" values="5;6;5" dur="4.5s" repeatCount="indefinite" />
              </circle>
              <circle cx="0" cy="-140" r="5" fill="#f9cb28" opacity="0.8">
                <animate attributeName="r" values="5;6;5" dur="5s" repeatCount="indefinite" />
              </circle>
            </g>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
