---
import { getTypeByCode } from "../../data/personality-types";

interface Props {
  types?: string[];
}

const defaultTypes = ["INTJ", "INFP", "ENTP", "ENFJ", "ISTP", "ESFJ"];

const { types = defaultTypes } = Astro.props;

const featuredTypes = types
  .map((code) => getTypeByCode(code))
  .filter((type): type is NonNullable<typeof type> => type !== undefined);
---

<section class="border-y border-hairline bg-canvas dark:border-white/10 dark:bg-primary">
  <div class="mx-auto max-w-[1000px] px-6 py-20 sm:py-28">
    <div class="text-center">
      <h2 class="text-balance font-semibold tracking-[-1.2px] text-ink text-[32px] leading-[1.1] sm:text-[40px] dark:text-on-primary">
        Start Exploring Your Type.
      </h2>
      <p class="mt-4 max-w-2xl mx-auto font-mono text-base leading-7 text-body dark:text-mute">
        Each personality type has a unique way of seeing the world. Here are six to get you started.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredTypes.map((type) => (
        <a
          href={`/personality-type/${type.code.toLowerCase()}`}
          class="group rounded-lg border border-hairline bg-canvas-soft p-8 transition hover:border-hairline-strong dark:border-white/15 dark:bg-primary dark:hover:border-white/30"
        >
          <span class="font-mono text-xs uppercase tracking-wide text-link">{type.code}</span>
          <h3 class="mt-2 text-lg font-semibold text-ink group-hover:text-link dark:text-on-primary dark:group-hover:text-link">
            {type.name}
          </h3>
          <p class="mt-2 text-sm leading-7 text-body dark:text-mute">{type.tagline}</p>
          <span class="mt-4 inline-block text-sm font-medium text-link">Read Profile →</span>
        </a>
      ))}
    </div>

    <div class="mt-14 text-center">
      <a
        href="/personality-types"
        class="rounded-pill border border-hairline px-8 py-3 text-base font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10"
      >
        Explore All Personality Types
      </a>
    </div>
  </div>
</section>
