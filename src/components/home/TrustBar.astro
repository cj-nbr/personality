---
interface Props {
  items?: Array<{ label: string }>;
}

const defaultItems = [
  { label: "Free" },
  { label: "No Account Required" },
  { label: "48 Questions" },
  { label: "Around 5 Minutes" },
  { label: "Instant Results" },
];

const { items = defaultItems } = Astro.props;
---

<div
  class="border-y border-hairline bg-canvas-soft dark:border-white/10 dark:bg-primary"
  aria-label="Trust indicators"
>
  <div class="mx-auto max-w-[1400px] px-6 py-6">
    <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10">
      {items.map((item) => (
        <span class="flex items-center gap-2 text-sm font-medium text-body dark:text-mute">
          <svg
            class="h-5 w-5 shrink-0 text-link"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M5 13l4 4L19 7"
            />
          </svg>
          {item.label}
        </span>
      ))}
    </div>
  </div>
</div>
