---
interface CardItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  items?: CardItem[];
}

const defaultItems = [
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    title: "Relationships",
    description: "You clash with the same people, over and over, without knowing why. Understanding your natural preferences changes how you communicate, connect, and resolve conflict.",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
    title: "Career",
    description: "You chase careers that look good on paper but leave you drained. Self-awareness helps you find work that aligns with how you actually think and recharge.",
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>`,
    title: "Personal Growth",
    description: "You try to change habits that run against your natural design. Self-knowledge lets you work with your tendencies instead of constantly fighting them.",
  },
];

const { items = defaultItems } = Astro.props;
---

<section class="border-y border-hairline bg-canvas dark:border-white/10 dark:bg-primary">
  <div class="mx-auto max-w-[1000px] px-6 py-20 sm:py-28">
    <div class="text-center">
      <h2 class="text-balance font-semibold tracking-[-1.2px] text-ink text-[32px] leading-[1.1] sm:text-[40px] dark:text-on-primary">
        Most People Spend a Lifetime Without Knowing How They Work.
      </h2>
      <p class="mt-6 max-w-2xl mx-auto font-mono text-base leading-7 text-body dark:text-mute">
        Self-awareness isn't self-absorption. It's the foundation of every good decision you'll ever make — from who you build relationships with, to how you spend your days.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-3">
      {items.map((item) => (
        <div class="rounded-lg border border-hairline bg-canvas p-8 transition hover:border-hairline-strong dark:border-white/15 dark:bg-primary dark:hover:border-white/30">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft text-link dark:bg-white/10">
            <span set:html={item.icon} />
          </div>
          <h3 class="mt-5 text-lg font-semibold text-ink dark:text-on-primary">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-body dark:text-mute">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
