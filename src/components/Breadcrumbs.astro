---
interface Props {
  items: Array<{ label: string; href?: string }>;
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6 text-sm">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && <span class="text-muted dark:text-muted" data-i18n="breadcrumb.separator">/</span>}
        {item.href ? (
          <a href={item.href} class="text-link hover:underline dark:text-link">{item.label}</a>
        ) : (
          <span class="font-medium text-ink dark:text-on-primary" aria-current="page">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
