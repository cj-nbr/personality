---
import TestLayout from "../../../layouts/TestLayout.astro";
import RelatedTypes from "../../../components/RelatedTypes.astro";
import { getTypeByCode, personalityTypes } from "../../../data/personality-types";

export function getStaticPaths() {
  return personalityTypes.map(type => ({ params: { code: type.code.toLowerCase() } }));
}

const code = Astro.params.code?.toUpperCase();
const type = getTypeByCode(code);

if (!type) {
  return Astro.redirect('/personality-types');
}
---

<TestLayout 
  title={`${type.code} Relationships | ${type.name}`} 
  description={`How ${type.name} (${type.code}) approaches romantic relationships, friendships, and family dynamics.`}
>
  <div class="mx-auto max-w-[1000px] px-6 py-12 sm:py-20">
    <div class="text-center">
      <span class="inline-flex items-center rounded-full bg-canvas-soft px-4 py-2 font-mono text-sm text-body dark:bg-white/10 dark:text-mute">
        Relationships
      </span>
      <h1 class="mt-4 text-5xl font-semibold tracking-[-2.4px] text-ink sm:text-6xl dark:text-on-primary">
        {type.code} Relationships
      </h1>
      <p class="mt-2 text-xl text-body dark:text-mute">{type.name}</p>
      <p class="mt-2 text-base font-mono text-mute">{type.tagline}</p>
    </div>

    <div class="mt-12 space-y-8">
      <div class="rounded-lg border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
        <h2 class="mb-4 text-xl font-semibold text-ink dark:text-on-primary">Romantic Relationships</h2>
        <p class="text-body leading-7 dark:text-mute">{type.romanticRelationships}</p>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
        <h2 class="mb-4 text-xl font-semibold text-ink dark:text-on-primary">Friendships</h2>
        <p class="text-body leading-7 dark:text-mute">{type.friendships}</p>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
        <h2 class="mb-4 text-xl font-semibold text-ink dark:text-on-primary">Family Relationships</h2>
        <p class="text-body leading-7 dark:text-mute">{type.familyRelationships}</p>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
        <h2 class="mb-4 text-xl font-semibold text-ink dark:text-on-primary">Communication Style</h2>
        <p class="text-body leading-7 dark:text-mute">{type.communicationStyle}</p>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="mb-6 text-xl font-semibold text-ink dark:text-on-primary">Related Personality Types</h2>
      <RelatedTypes types={type.relatedTypes.map(code => {
        const t = personalityTypes.find(pt => pt.code === code);
        return { code, name: t?.name || code, tagline: t?.tagline || '' };
      })} />
    </div>

    <div class="mt-12 flex items-center justify-center gap-4">
      <a 
        href={`/personality-type/${code.toLowerCase()}`}
        class="rounded-pill border border-hairline px-6 py-3 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10"
      >
        ← Back to Profile
      </a>
      <a 
        href="/personality-test"
        class="rounded-pill bg-primary px-8 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary"
      >
        Take the Test
      </a>
    </div>
  </div>
</TestLayout>
