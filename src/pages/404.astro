---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page Not Found" description="The page you are looking for could not be found.">
  <div class="min-h-screen bg-canvas dark:bg-primary flex items-center justify-center">
    <div class="max-w-2xl mx-auto px-4 py-16 text-center">
      <h1 class="text-6xl font-bold text-ink mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-ink mb-4">Page Not Found</h2>
      <p class="text-body text-lg mb-8">The page you are looking for could not be found. It may have been moved, deleted, or you entered the wrong URL.</p>
      <a href="/" class="inline-block rounded-pill bg-primary px-6 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary">
        Go Home
      </a>
    </div>
  </div>
</Layout>
