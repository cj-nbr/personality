---
import TestLayout from "../../layouts/TestLayout.astro";
import { getPostBySlug, blogPosts } from "../../data/blog-posts";

export function getStaticPaths() {
  return blogPosts.map(post => ({ params: { slug: post.slug } }));
}

const post = getPostBySlug(Astro.params.slug);

if (!post) {
  return Astro.redirect('/blog');
}
---

<TestLayout title={`${post.title} | personality Blog`} description={post.description}>
  <div class="mx-auto max-w-[800px] px-6 py-12 sm:py-20">
    <a href="/blog" class="text-sm text-link hover:text-link-deep dark:text-link dark:hover:text-link-deep">← Back to Blog</a>
    
    <h1 class="mt-4 text-4xl font-semibold tracking-[-2.4px] text-ink sm:text-5xl dark:text-on-primary">
      {post.title}
    </h1>
    
    <div class="mt-4 flex items-center gap-4">
      <span class="font-mono text-xs text-mute">{new Date(post.date).toLocaleDateString()}</span>
      <div class="flex gap-2">
        {post.tags.map(tag => (
          <span class="rounded-full bg-canvas-soft px-2 py-1 font-mono text-xs text-mute dark:bg-white/10">{tag}</span>
        ))}
      </div>
    </div>

    <div class="mt-8 prose prose-lg dark:prose-invert">
      <div set:html={post.content} class="text-body leading-7 dark:text-mute space-y-4" />
    </div>

    <div class="mt-12 rounded-lg border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
      <h2 class="text-xl font-semibold text-ink dark:text-on-primary">Ready to Discover Your Type?</h2>
      <p class="mt-2 text-body dark:text-mute">Take our free 16 personality test to learn more about yourself.</p>
      <a 
        href="/personality-test"
        class="mt-4 inline-block rounded-pill bg-primary px-8 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary"
      >
        Take the Test
      </a>
    </div>
  </div>
</TestLayout>
