---
import TestLayout from "../../layouts/TestLayout.astro";
import { blogPosts } from "../../data/blog-posts";
---

<TestLayout 
  title="Blog | Personality Insights and Guides" 
  description="Read articles about personality types, self-discovery, careers, relationships, and personal growth."
>
  <div class="mx-auto max-w-[1000px] px-6 py-12 sm:py-20">
    <h1 class="text-4xl font-semibold tracking-[-2.4px] text-ink sm:text-5xl dark:text-on-primary">
      Blog
    </h1>
    <p class="mt-4 max-w-2xl font-mono text-base leading-7 text-body dark:text-mute">
      Explore articles about personality types, self-discovery, and personal growth.
    </p>

    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-2">
      {blogPosts.map(post => (
        <a 
          href={`/blog/${post.slug}`}
          class="group rounded-lg border border-hairline bg-canvas p-6 transition hover:border-hairline-strong dark:border-white/15 dark:bg-primary dark:hover:border-white/30"
        >
          <span class="font-mono text-xs text-mute">{new Date(post.date).toLocaleDateString()}</span>
          <h2 class="mt-2 text-lg font-semibold text-ink group-hover:text-link dark:text-on-primary dark:group-hover:text-link">{post.title}</h2>
          <p class="mt-2 text-sm text-body dark:text-mute">{post.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {post.tags.map(tag => (
              <span class="rounded-full bg-canvas-soft px-2 py-1 font-mono text-xs text-mute dark:bg-white/10">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</TestLayout>
