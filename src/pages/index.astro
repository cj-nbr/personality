---
import Layout from "../layouts/Layout.astro";
import { countries } from "../data/countries";
---

<Layout title="TaxPortal - International Tax Information" description="Comprehensive tax information and calculators for countries worldwide.">
  <div class="min-h-screen">
    <section class="relative overflow-hidden">
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-canvas-soft to-canvas" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-7xl px-4 py-20 text-center sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold tracking-tight text-ink sm:text-5xl">TaxPortal</h1>
        <p class="mt-4 max-w-2xl mx-auto text-lg text-body">
          Comprehensive tax information and calculators for {countries.length} countries worldwide
        </p>
        <div class="mt-8 flex items-center justify-center gap-4">
          <a href="/countries" class="rounded-pill bg-primary px-6 py-3 text-base font-medium text-on-primary transition hover:opacity-90">Explore Countries</a>
        </div>
      </div>
    </section>

    <section class="border-t border-hairline dark:border-white/10">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-semibold text-ink mb-8">Featured Countries</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {countries.slice(0, 6).map(country => (
            <a href={`/countries/${country.slug}`} class="group rounded-xl border border-hairline bg-canvas p-6 transition hover:border-primary hover:shadow-lg">
              <div class="text-5xl mb-4">{country.flag}</div>
              <h3 class="text-xl font-semibold text-ink group-hover:text-primary">{country.name}</h3>
              <p class="text-sm text-muted mt-1">{country.continent}</p>
              <p class="text-sm text-body mt-3 line-clamp-2">{country.overview}</p>
              <span class="inline-block mt-4 text-sm font-medium text-link group-hover:underline">Explore taxes →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-hairline bg-canvas-soft dark:border-white/10 dark:bg-primary">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-semibold text-ink mb-8">Popular Calculators</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {countries.flatMap(c => c.popularCalculators.map(pc => ({ ...pc, country: c }))).slice(0, 6).map(item => (
            <a href={`/countries/${item.country.slug}/${item.category}/${item.slug}`} class="rounded-lg border border-hairline bg-canvas p-6 hover:border-primary transition dark:bg-primary">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-2xl">{item.country.flag}</span>
                <span class="text-sm text-muted">{item.country.name}</span>
              </div>
              <h3 class="font-semibold text-ink">{item.name}</h3>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-hairline dark:border-white/10">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-semibold text-ink mb-8">All Countries</h2>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
          {countries.map(country => (
            <a href={`/countries/${country.slug}`} class="flex items-center gap-3 rounded-lg border border-hairline bg-canvas p-4 hover:border-primary transition dark:bg-primary">
              <span class="text-3xl">{country.flag}</span>
              <span class="font-medium text-ink">{country.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
