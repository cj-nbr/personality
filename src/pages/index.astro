---
import Layout from "../layouts/Layout.astro";
import Header from "../components/home/Header.astro";
import Hero from "../components/home/Hero.astro";
import TrustBar from "../components/home/TrustBar.astro";
import WhySelfDiscovery from "../components/home/WhySelfDiscovery.astro";
import PlatformVision from "../components/home/PlatformVision.astro";
import ScientificApproach from "../components/home/ScientificApproach.astro";
import HowItWorks from "../components/home/HowItWorks.astro";
import DimensionsOverview from "../components/home/DimensionsOverview.astro";
import FeaturedTypes from "../components/home/FeaturedTypes.astro";
import ResultsPreview from "../components/home/ResultsPreview.astro";
import Testimonials from "../components/home/Testimonials.astro";
import FAQ from "../components/home/FAQ.astro";
import FinalCTA from "../components/home/FinalCTA.astro";
---

<Layout
  title="Free Personality Test & Self-Discovery Platform | personality"
  description="Take our free personality assessment to discover your type. A science-backed self-discovery platform with insights on personality, career, and relationships."
>
  <a
    href="#main"
    class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-sm focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-on-primary"
  >
    Skip to content
  </a>

  <Header transparent={true} />

  <main id="main">
    <Hero />
    <TrustBar />
    <WhySelfDiscovery />
    <PlatformVision />
    <ScientificApproach />
    <HowItWorks />
    <DimensionsOverview />
    <FeaturedTypes />
    <ResultsPreview />
    <Testimonials />
    <FAQ />
    <FinalCTA />
  </main>

  <footer class="border-t border-hairline bg-canvas px-6 py-16 dark:border-white/10 dark:bg-primary">
    <div class="mx-auto flex max-w-[1400px] flex-col items-center justify-between gap-4 text-sm text-body sm:flex-row dark:text-mute">
      <span class="font-mono">© <span id="year"></span> personality</span>
      <span class="font-mono">Built with Astro · Tailwind CSS v4 · Dark mode by default</span>
    </div>
  </footer>

  <script is:inline>
    document.getElementById("year").textContent = new Date().getFullYear();
  </script>
</Layout>
