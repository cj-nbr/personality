---
import Layout from "../layouts/Layout.astro";
---

<Layout title="personality" description="personality — a hello, from Astro + Tailwind CSS v4.">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-sm focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-on-primary">Skip to content</a>
  <!-- Nav bar -->
  <header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur dark:border-white/10 dark:bg-primary/80">
    <nav class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6">
      <a href="/" class="flex items-center gap-2 font-semibold tracking-tight text-ink dark:text-on-primary">
        <span class="grid h-6 w-6 place-items-center rounded-sm bg-primary text-[13px] text-on-primary dark:bg-on-primary dark:text-primary">p</span>
        personality
      </a>
      <div class="flex items-center gap-2">
        <a href="https://github.com/cj-nbr/personality" class="hidden text-sm text-body hover:text-ink sm:block dark:text-mute dark:hover:text-on-primary">GitHub</a>
        <button
          id="theme-toggle"
          class="grid h-8 w-8 place-items-center rounded-full border border-hairline text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10"
          aria-label="Toggle theme"
        >
          <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
          <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
      </div>
    </nav>
  </header>

  <main id="main">
    <!-- Hero band with mesh gradient backdrop -->
    <section class="relative overflow-hidden">
      <div class="mesh-gradient pointer-events-none absolute inset-0 opacity-60 dark:opacity-70" aria-hidden="true"></div>
      <div class="relative mx-auto flex max-w-[1400px] flex-col items-center px-6 py-32 text-center sm:py-40">
        <span class="mb-6 inline-flex items-center rounded-full bg-canvas-soft px-3 py-1 font-mono text-xs text-body dark:bg-white/10 dark:text-mute">
          personality · v0.1
        </span>
        <h1 class="max-w-3xl text-balance font-semibold tracking-[-2.4px] text-ink text-[40px] leading-[1.05] sm:text-[48px] dark:text-on-primary">
           Abhay chutiya hai 
           Abhay ma spark bohat hai lakin isha ko nhi dikha paya
           abhay ka gg
        </h1>
        <p class="mt-6 max-w-xl font-mono text-base leading-7 text-body dark:text-mute">
          A single page, for now. Built with Astro and Tailwind CSS v4 — designed in the spirit of Vercel.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
          <a
            href="https://github.com/cj-nbr/personality"
            class="rounded-pill bg-primary px-6 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary"
          >
            Get started
          </a>
          <a
            href="#domain"
            class="rounded-pill border border-hairline bg-canvas px-6 py-3 text-base font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:bg-transparent dark:text-on-primary dark:hover:bg-white/10"
          >
            Learn more
          </a>
        </div>
      </div>
    </section>

    <!-- Identity band -->
    <section id="domain" class="border-t border-hairline bg-canvas-soft dark:border-white/10 dark:bg-primary">
      <div class="mx-auto max-w-[1400px] px-6 py-24">
        <p class="mb-3 font-mono text-xs uppercase tracking-wide text-mute">Identity</p>
        <dl class="grid gap-8 sm:grid-cols-2">
          <div>
            <dt class="font-mono text-sm text-body dark:text-mute">Name</dt>
            <dd class="mt-1 font-semibold tracking-[-0.96px] text-2xl text-ink dark:text-on-primary">personality</dd>
          </div>
          <div>
            <dt class="font-mono text-sm text-body dark:text-mute">Domain</dt>
            <dd class="mt-1 font-semibold tracking-[-0.96px] text-2xl text-ink dark:text-on-primary">personality</dd>
          </div>
        </dl>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-hairline bg-canvas px-6 py-16 dark:border-white/10 dark:bg-primary">
    <div class="mx-auto flex max-w-[1400px] flex-col items-center justify-between gap-4 text-sm text-body sm:flex-row dark:text-mute">
      <span class="font-mono">© <span id="year"></span> personality</span>
      <span class="font-mono">Built with Astro · Tailwind CSS v4 · Dark mode by default</span>
    </div>
  </footer>

  <script is:inline>
    document.getElementById("year").textContent = new Date().getFullYear();

    var btn = document.getElementById("theme-toggle");
    btn.addEventListener("click", function () {
      var isDark = document.documentElement.classList.toggle("dark");
      try { localStorage.setItem("theme", isDark ? "dark" : "light"); } catch (e) {}
    });
  </script>
</Layout>
