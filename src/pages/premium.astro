---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout title="Premium Products | personality" description="Premium personality reports and career suites.">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-sm focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-on-primary">Skip to content</a>
  <header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur dark:border-white/10 dark:bg-primary/80">
    <nav class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6">
      <a href="/" class="flex items-center gap-2 font-semibold tracking-tight text-ink dark:text-on-primary">
        <span class="grid h-6 w-6 place-items-center rounded-sm bg-primary text-[13px] text-on-primary dark:bg-on-primary dark:text-primary">p</span>
        personality
      </a>
      <div class="flex items-center gap-1">
        <a href="/" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Home</a>
        <a href="/tools" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Tools</a>
        <a href="/shop" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Shop</a>
        <a href="/guide" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Guide</a>
        <a href="/profile" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Profile</a>
      </div>
    </nav>
  </header>

  <main id="main">
    <section class="relative overflow-hidden">
      <div class="mesh-gradient pointer-events-none absolute inset-0 opacity-60 dark:opacity-70" aria-hidden="true"></div>
      <div class="relative mx-auto flex max-w-[1400px] flex-col items-center px-6 py-32 text-center sm:py-40">
        <span class="mb-6 inline-flex items-center rounded-full bg-canvas-soft px-3 py-1 font-mono text-xs text-body dark:bg-white/10 dark:text-mute">
          Premium
        </span>
        <h1 class="shine-text max-w-3xl text-balance font-semibold tracking-[-2.4px] text-ink text-[40px] leading-[1.05] sm:text-[48px] dark:text-on-primary">
          Premium Reports
        </h1>
        <p class="mt-6 max-w-xl font-mono text-base leading-7 text-body dark:text-mute">
          Unlock detailed insights about your personality with our premium reports and career suites.
        </p>
      </div>
    </section>

    <section class="border-t border-hairline bg-canvas-soft dark:border-white/10 dark:bg-primary">
      <div class="mx-auto max-w-[1200px] px-6 py-24">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-xl border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
            <div class="text-sm font-mono text-mute">Most Popular</div>
            <h3 class="mt-2 text-2xl font-semibold text-ink dark:text-on-primary">Career Suite</h3>
            <p class="mt-4 text-body dark:text-mute">Comprehensive career guidance tailored to your personality type. Includes job recommendations, workplace strategies, and professional development plans.</p>
            <ul class="mt-6 space-y-2 text-sm text-body dark:text-mute">
              <li>• Detailed career path analysis</li>
              <li>• Workplace behavior insights</li>
              <li>• Professional development plan</li>
              <li>• Salary negotiation tips</li>
            </ul>
            <div class="mt-6 text-2xl font-semibold text-ink dark:text-on-primary">$29</div>
            <button class="mt-4 w-full rounded-pill bg-primary px-6 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary">
              Get Career Suite
            </button>
          </div>

          <div class="rounded-xl border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
            <div class="text-sm font-mono text-mute">Complete</div>
            <h3 class="mt-2 text-2xl font-semibold text-ink dark:text-on-primary">Pro Suite</h3>
            <p class="mt-4 text-body dark:text-mute">The ultimate personality package. Get every premium report including career, relationships, and personal growth guides.</p>
            <ul class="mt-6 space-y-2 text-sm text-body dark:text-mute">
              <li>• Everything in Career Suite</li>
              <li>• Relationship compatibility report</li>
              <li>• Personal growth roadmap</li>
              <li>• Stress management guide</li>
            </ul>
            <div class="mt-6 text-2xl font-semibold text-ink dark:text-on-primary">$49</div>
            <button class="mt-4 w-full rounded-pill bg-primary px-6 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary">
              Get Pro Suite
            </button>
          </div>

          <div class="rounded-xl border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
            <div class="text-sm font-mono text-mute">For Teams</div>
            <h3 class="mt-2 text-2xl font-semibold text-ink dark:text-on-primary">Team Assessment</h3>
            <p class="mt-4 text-body dark:text-mute">Understand your team's personality dynamics. Improve communication, collaboration, and productivity.</p>
            <ul class="mt-6 space-y-2 text-sm text-body dark:text-mute">
              <li>• Team composition analysis</li>
              <li>• Communication strategies</li>
              <li>• Conflict resolution guide</li>
              <li>• Leadership recommendations</li>
            </ul>
            <div class="mt-6 text-2xl font-semibold text-ink dark:text-on-primary">$99</div>
            <button class="mt-4 w-full rounded-pill bg-primary px-6 py-3 text-base font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary">
              Get Team Assessment
            </button>
          </div>
        </div>

        <div class="mt-16 text-center">
          <a 
            href="/personality-test"
            class="rounded-pill border border-hairline px-8 py-3 text-base font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10"
          >
            Take the Free Test First
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-hairline bg-canvas px-6 py-16 dark:border-white/10 dark:bg-primary">
    <div class="mx-auto flex max-w-[1400px] flex-col items-center justify-between gap-4 text-sm text-body sm:flex-row dark:text-mute">
      <span class="font-mono">© <span id="year"></span> personality</span>
      <span class="font-mono">Built with Astro · Tailwind CSS v4 · Dark mode by default</span>
    </div>
  </footer>

  <script is:inline>
    document.getElementById("year").textContent = new Date().getFullYear();
  </script>
</Layout>
