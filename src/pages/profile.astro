---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout title="Profile - personality" description="Manage your account, preferences, and test history.">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-sm focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-on-primary">Skip to content</a>
  <header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur dark:border-white/10 dark:bg-primary/80">
    <nav class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6">
      <a href="/" class="flex items-center gap-2 font-semibold tracking-tight text-ink dark:text-on-primary">
        <span class="grid h-6 w-6 place-items-center rounded-sm bg-primary text-[13px] text-on-primary dark:bg-on-primary dark:text-primary">p</span>
        personality
      </a>
      <div class="flex items-center gap-1">
        <a href="/" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Home</a>
        <a href="/tools" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Tools</a>
        <a href="/premium" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Premium</a>
        <a href="/guide" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Guide</a>
        <a href="/profile" class="rounded-pill px-3 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:text-on-primary dark:hover:bg-white/10">Profile</a>
      </div>
    </nav>
  </header>

  <main id="main">
    <section class="relative overflow-hidden">
      <div class="mesh-gradient pointer-events-none absolute inset-0 opacity-60 dark:opacity-70" aria-hidden="true"></div>
      <div class="relative mx-auto flex max-w-[1400px] flex-col items-center px-6 py-32 text-center sm:py-40">
        <span class="mb-6 inline-flex items-center rounded-full bg-canvas-soft px-3 py-1 font-mono text-xs text-body dark:bg-white/10 dark:text-mute">
          personality · v0.1
        </span>
        <h1 class="shine-text max-w-3xl text-balance font-semibold tracking-[-2.4px] text-ink text-[40px] leading-[1.05] sm:text-[48px] dark:text-on-primary">
          Profile
        </h1>
        <p class="mt-6 max-w-xl font-mono text-base leading-7 text-body dark:text-mute">
          Manage your account, preferences, and test history.
        </p>

        <div class="mt-10 w-full max-w-2xl">
          <div id="profile-content" class="rounded-lg border border-hairline bg-canvas p-8 text-left dark:border-white/15 dark:bg-primary">
            <div id="logged-out" class="hidden">
              <h3 class="text-lg font-semibold text-ink dark:text-on-primary">Sign In</h3>
              <p class="mt-2 text-sm text-body dark:text-mute">Sign in to save your results and access your profile across devices.</p>
              <div class="mt-6 space-y-4">
                <div>
                  <label class="block text-sm font-medium text-ink dark:text-on-primary">Email</label>
                  <input type="email" id="login-email" placeholder="you@example.com" class="mt-1 w-full rounded-md border border-hairline bg-canvas px-3 py-2 text-sm text-ink dark:border-white/15 dark:bg-primary dark:text-on-primary" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-ink dark:text-on-primary">Password</label>
                  <input type="password" id="login-password" placeholder="••••••••" class="mt-1 w-full rounded-md border border-hairline bg-canvas px-3 py-2 text-sm text-ink dark:border-white/15 dark:bg-primary dark:text-on-primary" />
                </div>
                <button onclick="login()" class="rounded-pill bg-primary px-4 py-2 text-sm font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary">Sign In</button>
                <p class="text-xs text-mute">Demo: enter any email/password to sign in</p>
              </div>
            </div>

            <div id="logged-in" class="hidden">
              <div class="flex items-center gap-4">
                <div class="grid h-12 w-12 place-items-center rounded-full bg-primary text-lg font-semibold text-on-primary dark:bg-on-primary dark:text-primary" id="profile-avatar">U</div>
                <div>
                  <h3 class="text-lg font-semibold text-ink dark:text-on-primary" id="profile-name">User</h3>
                  <p class="text-sm text-body dark:text-mute" id="profile-email">user@example.com</p>
                </div>
              </div>

              <div class="mt-8 space-y-6">
                <div>
                  <h4 class="text-sm font-semibold text-ink dark:text-on-primary">Preferences</h4>
                  <div class="mt-4 space-y-3">
                    <div class="flex items-center justify-between">
                      <span class="text-sm text-body dark:text-mute">Dark Mode</span>
                      <button onclick="toggleTheme()" class="rounded-pill border border-hairline px-4 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10" id="theme-btn">Toggle</button>
                    </div>
                    <div class="flex items-center justify-between">
                      <span class="text-sm text-body dark:text-mute">Save Results</span>
                      <span class="text-sm text-green-600 dark:text-green-400">Enabled</span>
                    </div>
                  </div>
                </div>

                <div>
                  <h4 class="text-sm font-semibold text-ink dark:text-on-primary">Test History</h4>
                  <div id="test-history" class="mt-4 space-y-2">
                    <p class="text-sm text-body dark:text-mute">No test results yet. <a href="/personality-test" class="text-link hover:text-link-deep dark:text-link dark:hover:text-link-deep">Take the test</a></p>
                  </div>
                </div>

                <button onclick="logout()" class="rounded-pill border border-hairline px-4 py-2 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10">Sign Out</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-hairline bg-canvas px-6 py-16 dark:border-white/10 dark:bg-primary">
    <div class="mx-auto flex max-w-[1400px] flex-col items-center justify-between gap-4 text-sm text-body sm:flex-row dark:text-mute">
      <span class="font-mono">© <span id="year"></span> personality</span>
      <span class="font-mono">Built with Astro · Tailwind CSS v4 · Dark mode by default</span>
    </div>
  </footer>

  <script is:inline>
    function login() {
      var email = document.getElementById('login-email').value || 'user@example.com';
      var name = email.split('@')[0];
      localStorage.setItem('user_name', name);
      localStorage.setItem('user_email', email);
      localStorage.setItem('user_logged_in', 'true');
      renderProfile();
    }

    function logout() {
      localStorage.removeItem('user_logged_in');
      localStorage.removeItem('user_name');
      localStorage.removeItem('user_email');
      renderProfile();
    }

    function toggleTheme() {
      var isDark = document.documentElement.classList.toggle('dark');
      try { localStorage.setItem('theme', isDark ? 'dark' : 'light'); } catch (e) {}
    }

    function renderProfile() {
      var loggedIn = localStorage.getItem('user_logged_in') === 'true';
      var loggedOut = document.getElementById('logged-out');
      var loggedInEl = document.getElementById('logged-in');
      
      if (loggedIn) {
        loggedOut.classList.add('hidden');
        loggedInEl.classList.remove('hidden');
        var name = localStorage.getItem('user_name') || 'User';
        var email = localStorage.getItem('user_email') || 'user@example.com';
        document.getElementById('profile-name').textContent = name.charAt(0).toUpperCase() + name.slice(1);
        document.getElementById('profile-email').textContent = email;
        document.getElementById('profile-avatar').textContent = name.charAt(0).toUpperCase();
        
        var testState = localStorage.getItem('personality_test_state');
        var historyEl = document.getElementById('test-history');
        if (testState) {
          var state = JSON.parse(testState);
          if (state.completed && state.resultCode) {
            historyEl.innerHTML = '<div class="rounded-md border border-hairline bg-canvas-soft p-4 dark:border-white/10 dark:bg-primary"><span class="font-mono text-sm text-link">' + state.resultCode + '</span><span class="ml-2 text-sm text-body dark:text-mute">- Most recent result</span></div>';
          } else {
            historyEl.innerHTML = '<p class="text-sm text-body dark:text-mute">Test in progress. <a href="/personality-test" class="text-link hover:text-link-deep dark:text-link dark:hover:text-link-deep">Continue</a></p>';
          }
        }
      } else {
        loggedOut.classList.remove('hidden');
        loggedInEl.classList.add('hidden');
      }
    }

    document.getElementById('year').textContent = new Date().getFullYear();
    renderProfile();
  </script>
</Layout>

