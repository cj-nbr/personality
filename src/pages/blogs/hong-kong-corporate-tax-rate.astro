              <a href="/countries/hong-kong" class="block rounded border p-4 hover:border-primary transition">More Hong Kong Calculators</a>
            </div>
          </div>

          <div class="mt-12">
            <h2 class="text-2xl font-semibold text-ink mb-6 dark:text-on-primary">Related Articles</h2>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              <a href="/blogs/hong-kong-profits-tax-guide" class="block rounded border p-4 hover:border-primary transition">Hong Kong Profits Tax Guide</a>
              <a href="/blogs/hong-kong-tax-allowances-deductions" class="block rounded border p-4 hover:border-primary transition">Hong Kong Tax Allowances and Deductions</a>
              <a href="/blogs/hong-kong-vs-singapore-tax-guide" class="block rounded border p-4 hover:border-primary transition">Hong Kong vs Singapore Tax</a>
