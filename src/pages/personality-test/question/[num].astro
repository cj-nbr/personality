---
import TestLayout from "../../../layouts/TestLayout.astro";
import QuestionCard from "../../../components/QuestionCard.astro";
import TestProgress from "../../../components/TestProgress.astro";
import { questions, getTotalQuestions } from "../../../data/questions";
import { loadProgress, getInitialState, saveProgress, clearProgress, getEstimatedTimeRemaining, calculateResult, getTypeFromScores, getTotalQuestions as getTotalQuestionsEngine } from "../../../test/test-engine";
import { getTypeByCode } from "../../../data/personality-types";

export function getStaticPaths() {
  return questions.map(q => ({ params: { num: q.id.toString() } }));
}

const num = parseInt(Astro.params.num);
const total = getTotalQuestions();
const question = questions.find(q => q.id === num);

if (!question) {
  return Astro.redirect('/personality-test');
}

let state = loadProgress();
if (!state || state.completed) {
  state = getInitialState();
}

const currentQuestion = state.currentQuestion;
const selectedAnswer = state.answers[num];
---

<TestLayout title={`Question ${num} | 16 Personality Test`} description={`Answer question ${num} of ${total} in our personality test.`}>
  <div class="mx-auto max-w-[800px] px-6 py-12 sm:py-20">
    <TestProgress current={currentQuestion} total={total} />
    
    <div class="mt-8">
      <QuestionCard 
        question={question} 
        selectedAnswer={selectedAnswer} 
        onSelect={(value) => {
          state.answers[num] = value;
          saveProgress(state);
        }}
      />
    </div>

    <div class="mt-8 flex items-center justify-between">
      {num > 1 ? (
        <a 
          href={`/personality-test/question/${num - 1}`}
          class="rounded-pill border border-hairline px-6 py-3 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10"
        >
          Previous
        </a>
      ) : (
        <a 
          href="/personality-test"
          class="rounded-pill border border-hairline px-6 py-3 text-sm font-medium text-ink transition hover:bg-canvas-soft-2 dark:border-white/15 dark:text-on-primary dark:hover:bg-white/10"
        >
          Back to Start
        </a>
      )}

      <span class="text-sm font-mono text-mute">
        {getEstimatedTimeRemaining(currentQuestion, total, state.startTime)} remaining
      </span>

      {num < total ? (
        <a 
          href={`/personality-test/question/${num + 1}`}
          class="rounded-pill bg-primary px-6 py-3 text-sm font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary"
        >
          Next
        </a>
      ) : (
        <a 
          href="/personality-test/results"
          onclick="localStorage.setItem('test_completed', 'true')"
          class="rounded-pill bg-primary px-6 py-3 text-sm font-medium text-on-primary transition hover:opacity-90 dark:bg-on-primary dark:text-primary"
        >
          See Results
        </a>
      )}
    </div>
  </div>
</TestLayout>

<script is:inline>
  document.addEventListener('answer-selected', (e) => {
    const value = parseInt(e.detail.value);
    const questionId = parseInt(e.detail.questionId);
    let state = JSON.parse(localStorage.getItem('personality_test_state') || '{}');
    state.answers = state.answers || {};
    state.answers[questionId] = value;
    if (!state.startTime) state.startTime = Date.now();
    localStorage.setItem('personality_test_state', JSON.stringify(state));
  });
</script>
