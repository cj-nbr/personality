---
import CountryLayout from "../../../layouts/CountryLayout.astro";
import { countries, getCountryBySlug } from "../../../data/countries";
import { getBaseUrl } from "../../../utils/routing";

export function getStaticPaths() {
  return countries.map(country => ({
    params: { slug: country.slug }
  }));
}

const country = getCountryBySlug(Astro.params.slug!);

if (!country) {
  return Astro.redirect("/countries");
}

const baseUrl = getBaseUrl();
---

<CountryLayout
  title={`${country.name} | TaxPortal`}
  description={country.overview}
  breadcrumbs={[
    { label: "Countries", href: "/countries" },
    { label: country.name }
  ]}
  canonical={`${baseUrl}/countries/${country.slug}`}
>
  <section class="mb-12">
    <div class="rounded-2xl border border-hairline bg-gradient-to-br from-canvas to-canvas-soft shadow-sm dark:border-white/15 dark:from-primary dark:to-primary">
      <div class="p-8 sm:p-10 lg:p-12">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
          <div class="flex-1">
            <div class="flex items-center gap-4 mb-4">
              <span class="text-5xl sm:text-6xl" aria-hidden="true">{country.flag}</span>
              <div>
                 <h1 class="text-3xl font-bold text-ink sm:text-4xl dark:text-on-primary"><span data-i18n="country.name">{country.name}</span></h1>
                 <p class="text-sm text-muted mt-1 dark:text-muted"><span data-i18n="country.continent_header">{country.continent}</span></p>
              </div>
            </div>
             <p class="text-lg text-body leading-relaxed mt-4 dark:text-muted"><span data-i18n="country.overview">{country.overview}</span></p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <a
                href={country.taxAuthorityUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-white transition hover:bg-primary-dark"
              >
                 <span data-i18n="country.official_tax_authority">{country.officialTaxAuthority}</span>
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          </div>
          <div class="grid w-full max-w-xs grid-cols-2 gap-4 lg:w-auto">
            <div class="rounded-xl border border-hairline bg-canvas p-4 dark:border-white/15 dark:bg-primary">
              <p class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="country.currency">Currency</p>
               <p class="mt-1 text-lg font-semibold text-ink dark:text-on-primary"><span data-i18n="country.currency_value">{country.currency}</span></p>
            </div>
            <div class="rounded-xl border border-hairline bg-canvas p-4 dark:border-white/15 dark:bg-primary">
              <p class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="country.capital">Capital</p>
               <p class="mt-1 text-lg font-semibold text-ink dark:text-on-primary"><span data-i18n="country.capital_value">{country.capital}</span></p>
            </div>
            <div class="rounded-xl border border-hairline bg-canvas p-4 dark:border-white/15 dark:bg-primary">
              <p class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="country.tax_authority">Tax Authority</p>
               <p class="mt-1 text-sm font-semibold text-ink leading-snug dark:text-on-primary"><span data-i18n="country.official_tax_authority_value">{country.officialTaxAuthority}</span></p>
            </div>
            <div class="rounded-xl border border-hairline bg-canvas p-4 dark:border-white/15 dark:bg-primary">
              <p class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="country.continent">Continent</p>
               <p class="mt-1 text-lg font-semibold text-ink dark:text-on-primary"><span data-i18n="country.continent_value">{country.continent}</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-semibold text-ink mb-6 dark:text-on-primary" data-i18n="country.tax_categories">Tax Categories</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {country.taxCategories.map(category => (
        <a
          href={`/countries/${country.slug}/${category.slug}`}
          class="group rounded-xl border border-hairline bg-canvas p-6 transition hover:border-primary hover:shadow-md dark:border-white/15 dark:bg-primary"
        >
          <div class="flex items-start justify-between">
             <h3 class="font-semibold text-ink group-hover:text-primary dark:text-on-primary"><span data-i18n="country.category_name">{category.name}</span></h3>
            <span aria-hidden="true" class="mt-1 text-lg text-muted transition group-hover:translate-x-1 group-hover:text-primary dark:text-muted dark:group-hover:text-link">→</span>
          </div>
           <p class="mt-2 text-sm text-body line-clamp-2 dark:text-muted"><span data-i18n="country.category_description">{category.description}</span></p>
          <div class="mt-4 flex items-center gap-4 text-xs text-muted dark:text-muted">
            <span>{category.calculators.length} <span data-i18n="country.calculators">calculators</span></span>
            <span>{category.guides.length} <span data-i18n="country.guides">guides</span></span>
            <span>{category.faqs.length} <span data-i18n="country.faqs">FAQs</span></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {country.popularCalculators.length > 0 && (
    <section class="mb-12">
    <h2 class="text-2xl font-semibold text-ink mb-6 dark:text-on-primary" data-i18n="country.popular_calculators">Popular Calculators</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {country.popularCalculators.map(calc => {
        const category = country.taxCategories.find(c => c.slug === calc.category);
        return (
          <a
            href={`/countries/${country.slug}/${calc.category}/${calc.slug}`}
            class="rounded-xl border border-hairline bg-gradient-to-br from-canvas to-canvas-soft p-6 transition hover:border-primary hover:shadow-md dark:border-white/15 dark:from-primary dark:to-primary"
          >
             <p class="text-xs font-medium uppercase tracking-wider text-primary dark:text-link">
               <span data-i18n="country.calc_category_name">{category?.name ?? calc.category}</span>
             </p>
             <h3 class="mt-2 font-semibold text-ink dark:text-on-primary"><span data-i18n="country.calc_name">{calc.name}</span></h3>
            <p class="mt-1 text-sm text-muted dark:text-muted" data-i18n="country.calculate_your_tax">Calculate your tax liability</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-link dark:text-link">
              <span data-i18n="country.try_calculator">Try calculator</span> <span aria-hidden="true">→</span>
            </span>
          </a>
        );
      })}
    </div>
  </section>
)}

  {country.latestUpdates.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-ink mb-6 dark:text-on-primary" data-i18n="country.latest_updates">Latest Updates</h2>
      <div class="space-y-4">
        {country.latestUpdates.map(update => (
          <div class="rounded-xl border border-hairline bg-canvas p-6 transition hover:border-hairline dark:border-white/15 dark:bg-primary">
            <div class="flex items-center gap-3 mb-2">
              <span class="inline-flex rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary dark:bg-primary/20 dark:text-link">
                {new Date(update.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric"
                })}
              </span>
            </div>
             <h3 class="font-semibold text-ink dark:text-on-primary"><span data-i18n="country.update_title">{update.title}</span></h3>
             <p class="mt-2 text-sm text-body dark:text-muted"><span data-i18n="country.update_description">{update.description}</span></p>
          </div>
        ))}
      </div>
    </section>
  )}

  {country.relatedCountries.length > 0 && (
    <section class="mb-12">
    <h2 class="text-2xl font-semibold text-ink mb-6 dark:text-on-primary" data-i18n="country.related_countries">Related Countries</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {country.relatedCountries.map(slug => {
        const related = getCountryBySlug(slug);
        if (!related) return null;
        return (
          <a
            href={`/countries/${related.slug}`}
            class="group rounded-xl border border-hairline bg-canvas p-6 transition hover:border-primary hover:shadow-md dark:border-white/15 dark:bg-primary"
          >
            <div class="flex items-center gap-3">
               <span class="text-3xl" aria-hidden="true">{related.flag}</span>
               <div>
                 <h3 class="font-semibold text-ink group-hover:text-primary dark:text-on-primary"><span data-i18n="country.related_name">{related.name}</span></h3>
                 <p class="text-xs text-muted dark:text-muted"><span data-i18n="country.related_continent">{related.continent}</span></p>
               </div>
             </div>
             <p class="mt-3 text-sm text-body line-clamp-2 dark:text-muted"><span data-i18n="country.related_overview">{related.overview}</span></p>
          </a>
        );
      })}
    </div>
  </section>
  )}
</CountryLayout>
