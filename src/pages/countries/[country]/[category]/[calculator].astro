---
import CountryLayout from "../../../../layouts/CountryLayout.astro";
import { getCountryBySlug, getCategoryBySlug } from "../../../../data/countries";

export function getStaticPaths() {
  const paths: { params: { country: string; category: string; calculator: string } }[] = [];
  const allCountries = [
    "united-states", "india", "hong-kong", "singapore", "indonesia",
    "malaysia", "new-zealand", "pakistan", "philippines", "united-kingdom"
  ];
  
  allCountries.forEach(countrySlug => {
    const country = getCountryBySlug(countrySlug);
    if (!country) return;
    
    country.taxCategories.forEach(category => {
      category.calculators.forEach(calc => {
        paths.push({
          params: {
            country: countrySlug,
            category: category.slug,
            calculator: calc.slug
          }
        });
      });
    });
  });
  
  return paths;
}

const country = getCountryBySlug(Astro.params.country!);
const category = getCategoryBySlug(Astro.params.country!, Astro.params.category!);
const calculator = category?.calculators.find(c => c.slug === Astro.params.calculator);

if (!country || !category || !calculator) {
  return Astro.redirect("/countries");
}
---

<CountryLayout
  title={`${calculator.name}`}
  description={calculator.description}
  breadcrumbs={[
    { label: "Countries", href: "/countries" },
    { label: country.name, href: `/countries/${country.slug}` },
    { label: category.name, href: `/countries/${country.slug}/${category.slug}` },
    { label: calculator.name }
  ]}
>
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-ink dark:text-on-primary"><span data-i18n="calculator.name">{calculator.name}</span></h1>
    <p class="mt-2 text-lg text-body dark:text-muted"><span data-i18n="calculator.description">{calculator.description}</span></p>
  </div>

  <div class="rounded-lg border border-hairline bg-canvas p-8 dark:border-white/15 dark:bg-primary">
    <p class="text-body leading-relaxed dark:text-muted" data-i18n="calculator.calculate_your_tax" data-i18n-vars={JSON.stringify({ category: category.name, country: country.name })}>
      Calculate your {category.name.toLowerCase()} using this {country.name} calculator.
      Enter your information below to get an estimate.
    </p>

      <div class="mt-8">
        <h2 class="text-2xl font-semibold text-ink mb-6 dark:text-on-primary" data-i18n="calculator.input">Calculator Input</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div>
            <label for="income" class="block text-sm font-medium text-ink mb-2 dark:text-on-primary" data-i18n="calculator.annual_income">Annual Income</label>
            <input
              type="number"
              id="income"
              autocomplete="off"
              class="w-full rounded-lg border border-hairline bg-canvas px-4 py-2 text-ink focus:border-primary focus:outline-none dark:border-white/15 dark:bg-primary dark:text-on-primary"
            />
          </div>
          <div>
            <label for="tax-year" class="block text-sm font-medium text-ink mb-2 dark:text-on-primary" data-i18n="calculator.tax_year">Tax Year</label>
            <select id="tax-year" class="w-full rounded-lg border border-hairline bg-canvas px-4 py-2 text-ink focus:border-primary focus:outline-none dark:border-white/15 dark:bg-primary dark:text-on-primary">
              <option data-i18n="calculator.year_2024">2024</option>
              <option data-i18n="calculator.year_2023">2023</option>
            </select>
          </div>
        </div>
      <button
        id="calc-btn"
        class="mt-6 rounded-lg bg-primary px-6 py-3 text-white font-medium hover:bg-primary-dark transition dark:bg-on-primary dark:text-primary"
        data-i18n="calculator.calculate">Calculate</button>
      <button
        id="reset-btn"
        class="mt-2 ml-4 rounded-lg border border-hairline px-6 py-3 text-ink font-medium hover:bg-canvas-soft transition dark:border-white/15 dark:bg-primary dark:text-on-primary dark:hover:bg-white/10"
        data-i18n="calculator.reset">Reset</button>
    </div>

    <div id="result" class="mt-8 hidden">
      <h3 class="text-xl font-semibold text-ink mb-4 dark:text-on-primary" data-i18n="calculator.estimated_tax">Estimated Tax</h3>
      <div class="rounded-lg bg-canvas-soft p-6 dark:bg-primary">
        <p class="text-3xl font-bold text-primary dark:text-on-primary" id="result-value">$0</p>
        <p class="text-sm text-muted mt-2 dark:text-muted" data-i18n="calculator.estimate_disclaimer">This is an estimate. Consult a tax professional for accurate calculations.</p>
      </div>
    </div>

    <div id="calc-error" class="mt-4 hidden">
      <p class="text-sm text-red-600 dark:text-red-400" data-i18n="calculator.please_enter_income">Please enter a valid income amount</p>
    </div>
  </div>

  <script is:inline>
    (function() {
      var incomeInput = document.getElementById('income');
      var calcBtn = document.getElementById('calc-btn');
      var resetBtn = document.getElementById('reset-btn');
      var resultDiv = document.getElementById('result');
      var resultValue = document.getElementById('result-value');
      var errorDiv = document.getElementById('calc-error');

      function calculate() {
        var income = parseFloat(incomeInput.value) || 0;
        
        if (income <= 0) {
          if (errorDiv) {
            errorDiv.classList.remove('hidden');
            resultDiv.classList.add('hidden');
          }
          return;
        }
        
        if (errorDiv) errorDiv.classList.add('hidden');
        var tax = income * 0.15;
        resultValue.textContent = '$' + tax.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        resultDiv.classList.remove('hidden');
      }

      function reset() {
        incomeInput.value = '';
        resultDiv.classList.add('hidden');
        errorDiv.classList.add('hidden');
      }

      if (calcBtn) calcBtn.addEventListener('click', calculate);
      if (resetBtn) resetBtn.addEventListener('click', reset);
    })();
  </script>
</CountryLayout>
