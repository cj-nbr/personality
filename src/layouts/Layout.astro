---
import "../styles/global.css";
import Header from "../components/Header.astro";
import { loadLocales, setLang, getLang, getDict, detectLanguage } from "../i18n";
import en from "../i18n/translations/en.json";
import hi from "../i18n/translations/hi.json";
import es from "../i18n/translations/es.json";
import fr from "../i18n/translations/fr.json";
import de from "../i18n/translations/de.json";
import zh from "../i18n/translations/zh.json";
import zhTW from "../i18n/translations/zh-TW.json";
import ja from "../i18n/translations/ja.json";
import ar from "../i18n/translations/ar.json";
import pt from "../i18n/translations/pt.json";
import ru from "../i18n/translations/ru.json";

loadLocales({ en, hi, es, fr, de, zh, "zh-TW": zhTW, ja, ar, pt, ru });

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title = "TaxPortal", description = "International tax information and calculators", image = "https://personality.com/og-image.png" } = Astro.props;
const initialLang = detectLanguage();
setLang(initialLang);
const initialDir = initialLang === 'ar' ? 'rtl' : 'auto';
---

<!doctype html>
<html lang={initialLang} dir={initialDir} class="dark:bg-primary" color-scheme="light dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="keywords" content="tax calculator, income tax calculator, payroll calculator, tax refund estimator, tax estimator, federal tax calculator, free tax calculator, capital gains tax calculator, vat calculator, gst calculator, stamp duty calculator, w4 calculator, 1099 tax calculator, self employment tax calculator, paycheck calculator, tax withholding calculator, tax bracket calculator, tax return calculator, tax refund calculator, irs tax calculator, hr block tax calculator, turbotax calculator, 234a interest calculator, 234b interest calculator, 234c interest calculator, 80gg calculator, ato tax calculator, hmrc tax calculator, salary after tax calculator, take home pay calculator, gross to net calculator,capital gains tax calculator on sale of property, 234a 234b 234c interest calculator, gst calculator online, gst interest calculator, gst late fee calculator, tds calculator, calculate tds on salary, capital gain calculator with indexation, capital gain calculator for ay 2022 23, old regime tax calculator, new regime tax calculator, stamp duty calculator 2021, hmrc income tax calculator, hmrc payroll calculator, hmrc ni calculator, ato income tax calculator, ato tax tables fortnightly, cra payroll calculator, lhdn calculator, bir tax calculator, fis calculator, tax on 30k salary, tax on 40k salary, tax on 60k salary, effective tax rate calculator, adjusted gross income calculator, taxable income calculator" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image || "https://personality.com/og-image.png"} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TaxPortal" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image || "https://personality.com/og-image.png"} />
    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="hi" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="es" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="fr" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="de" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="zh" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="zh-TW" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="ja" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="ar" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="pt" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="ru" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "TaxPortal",
        "url": "https://personality.com",
        "description": "Comprehensive international tax information and calculators"
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "TaxPortal",
        "url": "https://personality.com",
        "description": "International tax information and calculators"
      }
    </script>
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-canvas text-ink antialiased dark:bg-primary dark:text-on-primary">
    <Header />
    <main id="main-content" class="min-h-screen">
      <slot />
    </main>
    <footer class="border-t border-hairline bg-canvas py-12 dark:border-white/10 dark:bg-primary">
      <div class="mx-auto max-w-7xl px-4 text-center text-sm text-muted sm:px-6 lg:px-8 dark:text-muted">
        <nav class="flex flex-wrap items-center justify-center gap-6 mb-6">
          <a href="/about" class="text-link hover:underline dark:text-link">About</a>
          <a href="/editorial-policy" class="text-link hover:underline dark:text-link">Editorial Policy</a>
          <a href="/contact" class="text-link hover:underline dark:text-link">Contact us</a>
          <a href="/privacy" class="text-link hover:underline dark:text-link">Privacy Policy</a>
          <a href="/terms" class="text-link hover:underline dark:text-link">Terms</a>
        </nav>
        <p data-i18n="footer.disclaimer">TaxPortal. For informational purposes only. Consult a tax professional for advice.</p>
        <p class="mt-2">&copy; {new Date().getFullYear()} TaxPortal</p>
      </div>
    </footer>

    <script type="module">
      import { loadLocales, setLang, getLang, getDict } from "/src/i18n/client.ts";
      import en from "/src/i18n/translations/en.json";
      import hi from "/src/i18n/translations/hi.json";
      import es from "/src/i18n/translations/es.json";
      import fr from "/src/i18n/translations/fr.json";
      import de from "/src/i18n/translations/de.json";
      import zh from "/src/i18n/translations/zh.json";
      import zhTW from "/src/i18n/translations/zh-TW.json";
      import ja from "/src/i18n/translations/ja.json";
      import ar from "/src/i18n/translations/ar.json";
      import pt from "/src/i18n/translations/pt.json";
      import ru from "/src/i18n/translations/ru.json";
      loadLocales({ en, hi, es, fr, de, zh, "zh-TW": zhTW, ja, ar, pt, ru });

      const dict = getDict();
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const text = dict[key];
        if (text) {
          let final = text;
          const varsAttr = el.getAttribute('data-i18n-vars');
          if (varsAttr) {
            try {
              const vars = JSON.parse(varsAttr);
              final = final.replace(/\{(\w+)\}/g, (_, k) => (vars[k] !== undefined ? String(vars[k]) : _));
            } catch {}
          }
          el.textContent = final;
        }
      });

      document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
        const key = el.getAttribute('data-i18n-placeholder');
        if (!key) return;
        const text = dict[key];
        if (text) el.setAttribute('placeholder', text);
      });

      document.querySelectorAll('[data-i18n-title]').forEach((el) => {
        const key = el.getAttribute('data-i18n-title');
        if (!key) return;
        const text = dict[key];
        if (text) el.setAttribute('title', text);
      });

      window.addEventListener("lang-change", () => {
        const newDict = getDict();
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (!key) return;
          const text = newDict[key];
          if (text) {
            let final = text;
            const varsAttr = el.getAttribute('data-i18n-vars');
            if (varsAttr) {
              try {
                const vars = JSON.parse(varsAttr);
                final = final.replace(/\{(\w+)\}/g, (_, k) => (vars[k] !== undefined ? String(vars[k]) : _));
              } catch {}
            }
            el.textContent = final;
          }
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
          const key = el.getAttribute('data-i18n-placeholder');
          if (!key) return;
          const text = newDict[key];
          if (text) el.setAttribute('placeholder', text);
        });
        document.querySelectorAll('[data-i18n-title]').forEach((el) => {
          const key = el.getAttribute('data-i18n-title');
          if (!key) return;
          const text = newDict[key];
          if (text) el.setAttribute('title', text);
        });
        const event = new CustomEvent("i18n-updated", { bubbles: true });
        document.documentElement.dispatchEvent(event);
      });

      document.documentElement.addEventListener("lang-change", (e) => {
        const lang = (e as CustomEvent).detail?.lang || getLang();
        const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null);
        const nodes: Text[] = [];
        let node: Text | null;
        while ((node = walker.nextNode() as Text | null)) nodes.push(node);
        nodes.forEach((textNode) => {
          let text = textNode.textContent || "";
          let changed = false;
          let newText = text;
          const cDict = countryNames[lang] || countryNames.en;
          const catDict = categoryNames[lang] || categoryNames.en;
          for (const [enName, translated] of Object.entries(cDict)) {
            if (newText.includes(enName)) {
              newText = newText.replace(new RegExp(enName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), translated);
              changed = true;
            }
          }
          for (const [enName, translated] of Object.entries(catDict)) {
            if (newText.includes(enName)) {
              newText = newText.replace(new RegExp(enName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), translated);
              changed = true;
            }
          }
          if (changed && textNode.parentElement) {
            textNode.parentElement.textContent = newText;
          }
        });
      });
    </script>
  </body>
</html>
