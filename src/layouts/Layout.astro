---
import "../styles/global.css";
import Header from "../components/Header.astro";
import { loadLocales, setLang, getLang, getDict, detectLanguage } from "../i18n";
import en from "../locales/en.ts";
import hi from "../locales/hi.ts";
import es from "../locales/es.json";
import fr from "../locales/fr.json";
import de from "../locales/de.json";
import zh from "../locales/zh.json";
import ja from "../locales/ja.json";
import ar from "../locales/ar.json";
import pt from "../locales/pt.json";
import ru from "../locales/ru.json";

loadLocales({ en, hi, es, fr, de, zh, ja, ar, pt, ru });

interface Props {
  title?: string;
  description?: string;
}

const { title = "TaxPortal", description = "International tax information and calculators" } = Astro.props;
const initialLang = detectLanguage();
setLang(initialLang);
const initialDir = initialLang === 'ar' ? 'rtl' : 'auto';
---

<!doctype html>
<html lang={initialLang} dir={initialDir} class="dark:bg-primary" color-scheme="light dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || "https://taxportal.com").href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "TaxPortal",
        "url": "https://personality.com",
        "description": "Comprehensive international tax information and calculators"
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "TaxPortal",
        "url": "https://personality.com",
        "description": "International tax information and calculators"
      }
    </script>
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-canvas text-ink antialiased dark:bg-primary dark:text-on-primary">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="min-h-screen">
      <slot />
    </main>
    <footer class="border-t border-hairline bg-canvas py-12 dark:border-white/10 dark:bg-primary">
      <div class="mx-auto max-w-7xl px-4 text-center text-sm text-muted sm:px-6 lg:px-8 dark:text-muted">
        <p data-i18n="footer.disclaimer">TaxPortal. For informational purposes only. Consult a tax professional for advice.</p>
        <p class="mt-2">&copy; {new Date().getFullYear()} TaxPortal</p>
      </div>
    </footer>

    <script type="module">
      import { loadLocales, setLang, getLang, getDict } from "/src/i18n/client.ts";
      import en from "/src/locales/en.ts";
      import hi from "/src/locales/hi.ts";
      import es from "/src/locales/es.json";
      import fr from "/src/locales/fr.json";
      import de from "/src/locales/de.json";
      import zh from "/src/locales/zh.json";
      import ja from "/src/locales/ja.json";
      import ar from "/src/locales/ar.json";
      import pt from "/src/locales/pt.json";
      import ru from "/src/locales/ru.json";
      loadLocales({ en, hi, es, fr, de, zh, ja, ar, pt, ru });

      const dict = getDict();
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const text = dict[key];
        if (text) {
          let final = text;
          const varsAttr = el.getAttribute('data-i18n-vars');
          if (varsAttr) {
            try {
              const vars = JSON.parse(varsAttr);
              final = final.replace(/\{(\w+)\}/g, (_, k) => (vars[k] !== undefined ? String(vars[k]) : _));
            } catch {}
          }
          el.textContent = final;
        }
      });

      document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
        const key = el.getAttribute('data-i18n-placeholder');
        if (!key) return;
        const text = dict[key];
        if (text) el.setAttribute('placeholder', text);
      });

      document.querySelectorAll('[data-i18n-title]').forEach((el) => {
        const key = el.getAttribute('data-i18n-title');
        if (!key) return;
        const text = dict[key];
        if (text) el.setAttribute('title', text);
      });

      window.addEventListener("lang-change", () => {
        const newDict = getDict();
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (!key) return;
          const text = newDict[key];
          if (text) {
            let final = text;
            const varsAttr = el.getAttribute('data-i18n-vars');
            if (varsAttr) {
              try {
                const vars = JSON.parse(varsAttr);
                final = final.replace(/\{(\w+)\}/g, (_, k) => (vars[k] !== undefined ? String(vars[k]) : _));
              } catch {}
            }
            el.textContent = final;
          }
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
          const key = el.getAttribute('data-i18n-placeholder');
          if (!key) return;
          const text = newDict[key];
          if (text) el.setAttribute('placeholder', text);
        });
        document.querySelectorAll('[data-i18n-title]').forEach((el) => {
          const key = el.getAttribute('data-i18n-title');
          if (!key) return;
          const text = newDict[key];
          if (text) el.setAttribute('title', text);
        });
        const event = new CustomEvent("i18n-updated", { bubbles: true });
        document.documentElement.dispatchEvent(event);
      });

      document.documentElement.addEventListener("lang-change", () => {
        const lang = getLang();
        const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, null);
        const nodes: Text[] = [];
        let node: Text | null;
        while ((node = walker.nextNode() as Text | null)) nodes.push(node);
        nodes.forEach((textNode) => {
          let text = textNode.textContent || "";
          let changed = false;
          let newText = text;
          const cDict = countryNames[lang] || countryNames.en;
          const catDict = categoryNames[lang] || categoryNames.en;
          for (const [enName, translated] of Object.entries(cDict)) {
            if (newText.includes(enName)) {
              newText = newText.replace(new RegExp(enName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), translated);
              changed = true;
            }
          }
          for (const [enName, translated] of Object.entries(catDict)) {
            if (newText.includes(enName)) {
              newText = newText.replace(new RegExp(enName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), translated);
              changed = true;
            }
          }
          if (changed && textNode.parentElement) {
            textNode.parentElement.textContent = newText;
          }
        });
      });
    </script>
  </body>
</html>
